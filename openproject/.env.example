TAG=17-slim
HOCUSPOCUS_TAG=17.3.1
POSTGRES_VERSION=17

# Replace 192.168.1.10 with this PC's LAN IP or DNS name.
PORT=0.0.0.0:8080
OPENPROJECT_HTTPS=false
OPENPROJECT_HSTS=false
OPENPROJECT_HOST__NAME=192.168.1.10:8080
OPENPROJECT_ADDITIONAL__HOST__NAMES=web
OPENPROJECT_RAILS__RELATIVE__URL__ROOT=
OPENPROJECT_URL=http://web:8080
COLLABORATIVE_SERVER_URL=ws://192.168.1.10:8080/hocuspocus

POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE
COLLABORATIVE_SERVER_SECRET=CHANGE_ME_COLLABORATIVE_SERVER_SECRET

RAILS_MIN_THREADS=4
RAILS_MAX_THREADS=16
IMAP_ENABLED=false
PGDATA=pgdata
OPDATA=opdata
